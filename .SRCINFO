	makedepends = curl
	depends = glibc
	depends = podman
	depends = docker
	depends = gocryptfs
	depends = fuse3
	depends = openssh
	depends = util-linux
	depends = skopeo
	depends = qemu-full
	depends = qemu-img
	depends = virtiofsd
	depends = libvirt
	depends = tailscale
	depends = fuse-overlayfs
	depends = slirp4netns
	depends = libisoburn
	depends = cdrtools
	depends = edk2-ovmf
	depends = dnsmasq
	depends = swtpm
	depends = gnupg
	depends = pinentry
	depends = cloudflared-bin
	depends = gvisor-tap-vsock
	optdepends = android-tools: host adb for the remote `target: android` package-download install path
	optdepends = opusfile: SPICE audio codec, for an ov built with -tags spice_audio
	optdepends = portaudio: SPICE audio I/O, for an ov built with -tags spice_audio
	optdepends = libsecret: secret-tool CLI + pinentry-qt Secret Service passphrase auto-retrieval; ov itself uses the pure-Go go-keyring D-Bus client
	optdepends = dmidecode: SMBIOS inspection inside guests when debugging VM key-injection
	optdepends = openbsd-netcat: remote virt-manager/virt-viewer SPICE console over qemu+ssh (ov eval spice connects directly without it)
	optdepends = go-task: provides /usr/bin/task for `task build:ov` and dev workflows from a source checkout
	provides = ov
	conflicts = ov
	conflicts = ov-git
	replaces = ov-git
