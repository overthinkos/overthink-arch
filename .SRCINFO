pkgbase = opencharly-git
	pkgdesc = OpenCharly container management CLI — compose, build, deploy container boxes from configurable candies
	pkgver = 2026.159.1559
	pkgrel = 1
	url = https://github.com/overthinkos/overthink
	install = opencharly-git.install
	arch = x86_64
	license = MIT
	makedepends = go
	makedepends = git
	makedepends = curl
	depends = glibc
	depends = podman
	depends = gocryptfs
	depends = fuse3
	depends = openssh
	depends = util-linux
	depends = skopeo
	depends = qemu-full
	depends = qemu-img
	depends = virtiofsd
	depends = libvirt
	depends = tailscale
	depends = libarchive
	depends = iproute2
	depends = fuse-overlayfs
	depends = slirp4netns
	depends = libisoburn
	depends = cdrtools
	depends = edk2-ovmf
	depends = dnsmasq
	depends = swtpm
	depends = gnupg
	depends = pinentry
	optdepends = docker: alternative container engine — only needed for engine.run=docker (podman is the default)
	optdepends = cloudflared-bin: Cloudflare tunnels (AUR)
	optdepends = gvisor-tap-vsock: podman-machine networking — provides /usr/lib/podman/gvproxy (AUR)
	optdepends = nvidia-utils: nvidia-smi GPU detection + nvidia-ctk CDI generation (GPU targets only)
	optdepends = kubectl: Kubernetes deploys + charly eval k8s probes (kind:k8s targets only)
	optdepends = android-tools: host adb for the remote `target: android` package-download install path
	optdepends = opusfile: SPICE audio codec, for a charly built with -tags spice_audio
	optdepends = portaudio: SPICE audio I/O, for a charly built with -tags spice_audio
	optdepends = libsecret: secret-tool CLI + pinentry-qt Secret Service passphrase auto-retrieval; charly itself uses the pure-Go go-keyring D-Bus client
	optdepends = dmidecode: SMBIOS inspection inside guests when debugging VM key-injection
	optdepends = openbsd-netcat: remote virt-manager/virt-viewer SPICE console over qemu+ssh (charly eval spice connects directly without it)
	optdepends = go-task: provides /usr/bin/task for `task build:charly` and dev workflows from a source checkout
	provides = charly
	conflicts = overthink-git
	conflicts = ov-git
	replaces = overthink-git
	replaces = ov-git
	source = opencharly-git::git+file:///home/atrawog/Sync/Atrapub/av-overthink
	sha256sums = SKIP

pkgname = opencharly-git
